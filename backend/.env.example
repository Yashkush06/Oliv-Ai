# Oliv AI — Environment Variables Template
# Copy this to .env and fill in your values

# Google Gemini API key (required if using Gemini provider)
GEMINI_API_KEY=

# Optional: override Ollama base URL (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Optional: override config directory (default: ~/.oliv-ai)
OLIV_CONFIG_DIR=
